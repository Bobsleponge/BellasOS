{
  "name": "bellasos",
  "version": "0.1.0",
  "private": true,
  "description": "BellasOS - a modular, event-driven, AI-agnostic personal intelligence and automation operating system.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "libs/shared/*",
    "libs/core/*",
    "libs/ai/*",
    "libs/memory/*",
    "libs/agents/*",
    "libs/modules/*",
    "libs/runtime",
    "apps/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "dev:api": "npm run dev -w @bellasos/api",
    "dev:worker": "npm run dev -w @bellasos/worker",
    "dev:web": "npm run dev -w @bellasos/web",
    "db:migrate": "npm run migrate -w @bellasos/db",
    "graph": "nx graph",
    "infra:up": "docker compose -f infra/compose/docker-compose.yml -f infra/compose/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/compose/docker-compose.yml -f infra/compose/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nx": "^20.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
