{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@bellasos/contracts": ["libs/shared/contracts/src/index.ts"],
      "@bellasos/observability": ["libs/shared/observability/src/index.ts"],
      "@bellasos/db": ["libs/shared/db/src/index.ts"],
      "@bellasos/ui": ["libs/shared/ui/src/index.ts"],
      "@bellasos/core-events": ["libs/core/events/src/index.ts"],
      "@bellasos/core-registry": ["libs/core/registry/src/index.ts"],
      "@bellasos/core-auth": ["libs/core/auth/src/index.ts"],
      "@bellasos/core-config": ["libs/core/config/src/index.ts"],
      "@bellasos/core-audit": ["libs/core/audit/src/index.ts"],
      "@bellasos/core-notifications": ["libs/core/notifications/src/index.ts"],
      "@bellasos/core-ingestion": ["libs/core/ingestion/src/index.ts"],
      "@bellasos/core-jarvis-intelligence": ["libs/core/jarvis-intelligence/src/index.ts"],
      "@bellasos/core-jarvis-cognition": ["libs/core/jarvis-cognition/src/index.ts"],
      "@bellasos/ai-gateway": ["libs/ai/gateway/src/index.ts"],
      "@bellasos/ai-providers": ["libs/ai/providers/src/index.ts"],
      "@bellasos/ai-routing": ["libs/ai/routing/src/index.ts"],
      "@bellasos/ai-model-registry": ["libs/ai/model-registry/src/index.ts"],
      "@bellasos/memory": ["libs/memory/memory/src/index.ts"],
      "@bellasos/agents-framework": ["libs/agents/framework/src/index.ts"],
      "@bellasos/agents-orchestrator": ["libs/agents/orchestrator/src/index.ts"],
      "@bellasos/agents-pool": ["libs/agents/pool/src/index.ts"],
      "@bellasos/runtime": ["libs/runtime/src/index.ts"],
      "@bellasos/module-llm": ["libs/modules/llm/src/index.ts"],
      "@bellasos/module-research": ["libs/modules/research/src/index.ts"],
      "@bellasos/module-intelligence": ["libs/modules/intelligence/src/index.ts"],
      "@bellasos/module-portfolio": ["libs/modules/portfolio/src/index.ts"],
      "@bellasos/module-social": ["libs/modules/social/src/index.ts"],
      "@bellasos/module-automation": ["libs/modules/automation/src/index.ts"],
      "@bellasos/module-voice": ["libs/modules/voice/src/index.ts"],
      "@bellasos/module-camera": ["libs/modules/camera/src/index.ts"],
      "@bellasos/module-coding": ["libs/modules/coding/src/index.ts"],
      "@bellasos/module-finance": ["libs/modules/finance/src/index.ts"],
      "@bellasos/module-finance-tracker": ["libs/modules/finance-tracker/src/index.ts"],
      "@bellasos/module-execution": ["libs/modules/execution/src/index.ts"],
      "@bellasos/module-workspace": ["libs/modules/workspace/src/index.ts"],
      "@bellasos/module-hybrid": ["libs/modules/hybrid/src/index.ts"],
      "@bellasos/core-external-apps": ["libs/core/external-apps/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp", ".next"]
}
