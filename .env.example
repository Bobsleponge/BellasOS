# ----------------------------------------------------------------------------
# BellasOS environment configuration (copy to .env and fill in)
# ----------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=debug

# --- Core API ---
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_PATH=/api/v1
WEB_ORIGIN=http://localhost:3000

# --- PostgreSQL (pgvector) ---
DATABASE_URL=postgres://bellasos:bellasos@localhost:5432/bellasos
PGVECTOR_DIMENSIONS=1536

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- NATS (JetStream) ---
NATS_URL=nats://localhost:4222
# If unset/unreachable, the event bus falls back to an in-process emitter.

# --- Keycloak (OIDC) ---
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/bellasos
KEYCLOAK_CLIENT_ID=bellasos-api
KEYCLOAK_CLIENT_SECRET=change-me
# When AUTH_MODE=dev the API mints/accepts a local dev token (no Keycloak needed).
AUTH_MODE=dev
AUTH_JWT_SECRET=dev-only-insecure-secret-change-me
# Shared secret for Wealth iframe SSO with Finance-Tracker (defaults to AUTH_JWT_SECRET)
BELLASOS_EMBED_SECRET=dev-only-insecure-secret-change-me

# --- Secrets backend (env|vault) ---
SECRETS_BACKEND=env

# --- AI provider credentials (only set the ones you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default routing preference: cost | latency | privacy | quality
AI_ROUTING_STRATEGY=privacy
# Hybrid: OpenAI leads + reviews; local Ollama executes (openai-lead | off)
JARVIS_HYBRID_MODE=openai-lead
# Spend profile: economy | balanced | premium (default premium — ~100x more OpenAI involvement than economy)
HYBRID_PROFILE=premium
# Optional overrides (unset = use profile defaults)
# JARVIS_GUIDE_MODEL=gpt-4o
# JARVIS_GUIDE_MAX_TOKENS=1200
# HYBRID_REVIEW_MODEL=gpt-4o
# HYBRID_REVIEW_MAX_TOKENS=800
# HYBRID_REVIEW_MAX_LOOPS=2
# HYBRID_REVIEW_ENABLED=true
# HYBRID_SYNTHESIS_ENABLED=true
# HYBRID_SYNTHESIS_MODEL=gpt-4o-mini
# HYBRID_SYNTHESIS_MAX_TOKENS=1500
# HYBRID_LEAD_FAST_TIER=true
# Jarvis hub: auto-picks model by question (fast/standard/deep). Override with JARVIS_MODEL if needed.
JARVIS_MODEL=
JARVIS_PREFER_CLOUD_FOR_DEEP=false
JARVIS_SEARCH_TIMEOUT_MS=6000

# Jarvis voice — cloud TTS (recommended) with browser fallback
# Provider: auto | openai | elevenlabs | none
JARVIS_TTS_PROVIDER=auto
# OpenAI voices: nova, shimmer (female), coral, sage, alloy, echo, fable, onyx
JARVIS_TTS_VOICE=nova
JARVIS_TTS_MODEL=tts-1
# JARVIS_TTS_SPEED=0.95
# ElevenLabs (optional — used first when key is set and provider=auto)
# ELEVENLABS_API_KEY=
# JARVIS_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# JARVIS_ELEVENLABS_MODEL=eleven_turbo_v2_5
# Frontend: auto tries cloud then browser; cloud = cloud only; browser = local only
# NEXT_PUBLIC_JARVIS_TTS=auto
# Browser fallback tuning (Windows: Microsoft Zira; macOS: Samantha)
# NEXT_PUBLIC_JARVIS_VOICE=Microsoft Zira
# NEXT_PUBLIC_JARVIS_SPEECH_RATE=0.93
# NEXT_PUBLIC_JARVIS_SPEECH_PITCH=1.08

# --- Speech-to-text (local Whisper via transformers.js) ---
# Recommended: whisper-medium.en for much better accuracy (~3–5 GB RAM on first load).
# Lighter/faster: whisper-small.en or whisper-base.en
STT_MODEL=Xenova/whisper-medium.en
STT_WARMUP=true
NEXT_PUBLIC_SILENCE_MS=1400

# --- Data ingestion (live sources for research/intelligence/portfolio) ---
# Optional: improves search quality (DuckDuckGo + Wikipedia work without keys)
TAVILY_API_KEY=
SERPER_API_KEY=
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
FINNHUB_API_KEY=
INGEST_FEED_POLL_MINUTES=30
INGEST_BOOT_COLLECT=true
INGEST_RSS_URLS=
INGEST_REDDIT_SUBS=worldnews,investing,stocks,energy,mining,artificial
INGEST_YAHOO_SYMBOLS=SPY,QQQ,GLD,USO,BHP,RIO,NVDA,AAPL,MSFT
INGEST_FOREX_PAIRS=USDZAR=X,EURUSD=X,GBPUSD=X,USDJPY=X

# --- Portfolio / Finance Tracker embed ---
# Full Finance Tracker app (dashboard, assets, investments, etc.) runs separately on port 5000.
NEXT_PUBLIC_FINANCE_TRACKER_URL=http://localhost:5000
# Service API key for Jarvis/agents (create via: node scripts/create-service-api-key.mjs)
FINANCE_TRACKER_URL=http://localhost:5000
FINANCE_TRACKER_API_KEY=
# Legacy cookie auth fallback (deprecated — use API key instead)
# FINANCE_TRACKER_EMAIL=admin@familyfinance.co.za
# FINANCE_TRACKER_PASSWORD=admin
# FINANCE_TRACKER_PATH=../Finance-Tracker
