[
  {
    "id": "wealth",
    "name": "Wealth",
    "ownership": "hybrid",
    "description": "Unified personal finance — live household accounts plus portfolio analysis.",
    "aliases": ["Wealth", "finance app", "portfolio app", "money app"],
    "jarvisGuide": "Wealth combines Finance Tracker (live household system of record) and BellasOS Portfolio (holdings analysis). Finance Tracker handles net worth, expenses, income, assets, liabilities, and smart share transactions in ZAR — route live money questions to the finance agent via bellasos.finance-tracker. Portfolio handles allocation analysis and holdings view — NOT live household data; route analysis-only questions to the portfolio agent via bellasos.portfolio. Live stock quotes and USD/ZAR are fetched automatically for smart transactions — never ask the user for prices or exchange rates. Account types: TFSA, RA, taxable, pension.",
    "primaryDomain": "wealth",
    "secondaryDomains": ["execution", "intelligence"],
    "systemOfRecord": true,
    "integration": {
      "type": "iframe",
      "standaloneRoute": "/finance"
    },
    "moduleIds": ["bellasos.finance-tracker", "bellasos.portfolio"],
    "capabilities": [
      {
        "id": "wealth.summary.get",
        "name": "Net worth summary",
        "description": "Live net worth and cashflow from Finance Tracker",
        "access": "read",
        "freshness": "live",
        "approval": "none",
        "intentExamples": ["What is my net worth?", "Show my financial information"],
        "implementation": { "moduleId": "bellasos.finance-tracker", "action": "summary.get" }
      },
      {
        "id": "wealth.investments.add",
        "name": "Smart transaction",
        "description": "Record investment purchase with live quotes",
        "access": "write",
        "freshness": "live",
        "approval": "confirm",
        "intentExamples": ["Buy R4000 of Nvidia", "Make a smart transaction"],
        "implementation": { "moduleId": "bellasos.finance-tracker", "action": "investments.add" }
      },
      {
        "id": "wealth.portfolio.analyze",
        "name": "Analyze portfolio",
        "description": "AI portfolio allocation analysis",
        "access": "analyze",
        "freshness": "live",
        "approval": "none",
        "intentExamples": ["Analyze my portfolio", "Portfolio allocation"],
        "implementation": { "moduleId": "bellasos.portfolio", "action": "analyze" }
      },
      {
        "id": "wealth.portfolio.summary",
        "name": "Portfolio summary",
        "description": "Holdings and allocation summary",
        "access": "read",
        "freshness": "cached",
        "approval": "none",
        "intentExamples": ["Portfolio summary", "Show my holdings"],
        "implementation": { "moduleId": "bellasos.portfolio", "action": "summary" }
      },
      {
        "id": "wealth.portfolio.performance",
        "name": "Portfolio performance",
        "description": "Weighted average ROI from holdings cost basis vs live prices",
        "access": "read",
        "freshness": "live",
        "approval": "none",
        "intentExamples": ["What is my portfolio return?", "Average ROI on investments"],
        "implementation": { "moduleId": "bellasos.portfolio", "action": "performance" }
      }
    ]
  },
